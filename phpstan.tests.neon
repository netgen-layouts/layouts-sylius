parameters:
    level: 8

    paths:
        - tests

    ignoreErrors:
        # Disable errors about missing value types in PHPUnit data providers

        - '#Method .+Test::\w+DataProvider\(\) return type has no value type specified in iterable type iterable.#'

        # Netgen Layouts

        - '#Method Netgen\\Layouts\\Sylius\\Tests\\Validator\\RepositoryValidatorFactory::__construct\(\) has parameter \$repository with generic interface#'
