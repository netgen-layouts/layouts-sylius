{
    "name": "netgen/layouts-sylius",
    "description": "Netgen Layouts & Sylius eCommerce integration",
    "license": "MIT",
    "type": "symfony-bundle",
    "authors": [
        {
            "name": "Netgen",
            "homepage": "https://netgen.io"
        }
    ],
    "require": {
        "php": "^8.4",
        "netgen/layouts-core": "~2.0.0",
        "netgen/content-browser-sylius": "^2.0",
        "doctrine/orm": "^3.5",
        "sylius/sylius": "^2.1",
        "sylius/resource-bundle": "^1.13",
        "jean85/pretty-package-versions": "^2.1"
    },
    "require-dev": {
        "netgen/layouts-coding-standard": "^3.0",
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "matthiasnoback/symfony-dependency-injection-test": "^6.2"
    },
    "config": {
        "allow-plugins": false
    },
    "scripts": {
        "test": "@php vendor/bin/phpunit -c phpunit.xml --colors=always",
        "coverage": "@php -dzend_extension=xdebug.so -dxdebug.mode=coverage vendor/bin/phpunit -c phpunit.xml --coverage-html=coverage --colors=always",
        "phpstan": "@php vendor/bin/phpstan analyse -c phpstan.neon --ansi",
        "phpstan-tests": "@php vendor/bin/phpstan analyse -c phpstan.tests.neon --ansi"
    },
    "autoload": {
        "psr-4": {
            "Netgen\\Layouts\\Sylius\\": "lib/",
            "Netgen\\Bundle\\LayoutsSyliusBundle\\": "bundle/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Netgen\\Layouts\\Sylius\\Tests\\": "tests/lib/",
            "Netgen\\Bundle\\LayoutsSyliusBundle\\Tests\\": "tests/bundle/",
            "Netgen\\Layouts\\Tests\\": "vendor/netgen/layouts-core/tests/lib/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-master": "2.0.x-dev"
        }
    }
}
